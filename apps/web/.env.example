# GA4 Measurement ID — public, non-sensitive identifier.
# The production value is committed in .env.production.
# Set here to override during local development, or leave blank to disable analytics.
VITE_GA_MEASUREMENT_ID=

# Reddit Pixel ID (e.g. "a2_xxxxxxxxxxxx") — public, non-sensitive identifier.
# Used for Reddit ad conversion tracking and retargeting. Leave blank to
# disable Reddit ads tracking entirely (pixel module becomes a no-op).
VITE_REDDIT_PIXEL_ID=

# Canonical public origin used when generating shareable URLs (UTM tags,
# QR codes, short links) from the admin panel. The admin panel is reached
# via Tailscale, so window.location.origin is wrong for these surfaces.
# Leave blank to use the production default of https://price.games. Set
# this for preview/sandbox environments that need their own public origin.
VITE_PUBLIC_SITE_URL=
