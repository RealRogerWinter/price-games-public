# Admin API base URL the extension talks to, injected at build time.
#
# Production: your server's Tailscale hostname, e.g.
#   VITE_EXTENSION_API_BASE=https://<tailscale-hostname>.ts.net/api/admin
#
# Local development (default if unset): http://localhost:3001/api/admin
#
# Copy this file to `.env.production` (or pass the var via the shell) before
# running `npm run build -w apps/extension`, then distribute the built
# extension.
# VITE_EXTENSION_API_BASE=https://your-tailscale-hostname.ts.net/api/admin
