    "@price-game/shared": "*",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.1.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.6.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.6",
    "node-html-parser": "^7.1.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.3",
    "socket.io": "^4.8.3",
