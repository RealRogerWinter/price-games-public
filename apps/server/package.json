    "restore": "tsx src/pipeline/backup-restore.ts restore",
    "backup:status": "tsx src/pipeline/backup-restore.ts status",
    "verify": "tsx src/pipeline/verify-products.ts",
    "verify:fix": "tsx src/pipeline/verify-products.ts --fix",
    "contacts": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts",
    "contacts:extract": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts extract",
    "contacts:status": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts status",
    "contacts:pending": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts pending",
    "contacts:backup": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts backup",
    "contacts:dump": "tsx src/pipeline/manufacturer-contacts/run-pipeline.ts dump"
  },
  "dependencies": {
