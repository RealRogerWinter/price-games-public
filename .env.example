# Server port (default: 3001)
PORT=3001

# Comma-separated allowed CORS origins (default: localhost + price.games)
# ALLOWED_ORIGINS=https://price.games,https://www.price.games

# Node environment (production, development)
NODE_ENV=production

# REST API rate limit — requests per minute per IP (default: 60)
# API_RATE_LIMIT=60

# Image proxy rate limit — requests per minute per IP (default: 30)
# IMAGE_RATE_LIMIT=30

# Image proxy curl timeout in seconds (default: 10)
# IMAGE_PROXY_TIMEOUT=10

# Image URL cache max size (default: 5000)
# IMAGE_CACHE_SIZE=5000

# Socket.IO ping interval in ms (default: 15000)
# SOCKET_PING_INTERVAL=15000

# Socket.IO ping timeout in ms (default: 10000)
# SOCKET_PING_TIMEOUT=10000

# Max socket events per second per connection (default: 30)
# SOCKET_MAX_EVENTS_PER_SEC=30

# Room cleanup interval in ms (default: 60000)
# ROOM_CLEANUP_INTERVAL=60000

# Max room creation per minute per IP (default: 5)
# ROOM_CREATE_LIMIT=5

# Max join attempts per minute per room code (default: 5)
# ROOM_JOIN_LIMIT=5

# ── Admin Panel ──────────────────────────────────────────────────────────

# Initial admin username/password — only used when admin_users table is empty.
# WARNING: Generate a strong password (min 12 chars). Remove these vars after first login.
# Example: openssl rand -base64 18
# ADMIN_INITIAL_USERNAME=admin
# ADMIN_INITIAL_PASSWORD=<generate-a-strong-password>

# Admin session cookie name (default: admin_session)
# ADMIN_COOKIE_NAME=admin_session

# Admin session absolute lifetime in ms (default: 28800000 = 8 hours)
# ADMIN_SESSION_DURATION_MS=28800000

# Admin session idle timeout in ms (default: 1800000 = 30 minutes)
# ADMIN_IDLE_TIMEOUT_MS=1800000

# Bcrypt salt rounds for admin password hashing (default: 12)
# ADMIN_BCRYPT_ROUNDS=12

# AES-256 key (64 hex chars) used to encrypt admin TOTP secrets at rest.
# REQUIRED whenever 2FA is enabled — any 2FA setup/verify call throws if
# this is empty. Generate with:
#   openssl rand -hex 32
# ADMIN_2FA_ENCRYPTION_KEY=

# Max failed login attempts before account lockout (default: 5)
# ADMIN_MAX_FAILED_LOGINS=5

# Account lockout duration in ms (default: 900000 = 15 minutes)
# ADMIN_LOCKOUT_DURATION_MS=900000

# Admin login rate limit — attempts per window per IP (default: 5)
# ADMIN_LOGIN_RATE_LIMIT=5

# Admin login rate limit window in ms (default: 900000 = 15 minutes)
# ADMIN_LOGIN_RATE_WINDOW_MS=900000

# Expired session cleanup interval in ms (default: 900000 = 15 minutes)
# ADMIN_SESSION_CLEANUP_INTERVAL_MS=900000

# Skip 2FA requirement for admin routes — sandbox/dev ONLY, never production.
# SKIP_ADMIN_2FA=1

# ── Email (Resend) ──────────────────────────────────────────────────────

# Resend API key — required for sending transactional emails
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# From address for outgoing emails (default: Price Games <noreply@price.games>)
# EMAIL_FROM=Price Games <noreply@price.games>

# Public app URL for links in emails (default: http://localhost:5173)
# APP_URL=http://localhost:5173

# ── Email Notifications (marketing / re-engagement channel) ───────────
#
# Separate cadence from push. See docs/EMAIL_NOTIFICATIONS.md. Uses the
# same Resend transport as transactional email above; these knobs tune
# the triggering, cooldowns, and queue behavior for the marketing loop.

# Scheduler tick interval (default: 900000 = 15 min). Coarser than push
# by design — email triggers are time-of-day aware and cooldown-bounded,
# so higher frequency just burns cycles.
# EMAIL_SCHEDULER_INTERVAL_MS=900000

# Hard-floor cooldown between ANY two marketing emails to the same user,
# in hours (default: 24). Admin sends can bypass with adminOverride=true;
# scheduler-driven sends never bypass this.
# EMAIL_GLOBAL_COOLDOWN_HOURS=24

# Max scheduled rows drained per tick (default: 50).
# EMAIL_MAX_PER_TICK=50

# Retry cap for failed scheduled sends (default: 3).
# EMAIL_MAX_ATTEMPTS=3

# HMAC secret for one-click unsubscribe tokens. REQUIRED in production —
# leaving this empty logs a warning on boot and tokens are signed with a
# known default value, making them forgeable. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# EMAIL_UNSUB_SECRET=

# Signing secret for the Resend (Svix) webhook that delivers
# email.opened / email.bounced / email.complained events. When this is
# empty the webhook endpoint returns 503 — this is the correct default
# because an unauthenticated webhook lets anyone forge bounce events
# and force-unsubscribe real users. Get the secret from the Resend
# dashboard when you configure the webhook; it typically starts with
# `whsec_`.
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# ── User Accounts ─────────────────────────────────────────────────────

# User session cookie name (default: user_session)
# USER_COOKIE_NAME=user_session

# User session absolute lifetime in ms (default: 2592000000 = 30 days)
# Applied when "Stay logged in" is checked at login (or omitted by legacy clients).
# USER_SESSION_DURATION_MS=2592000000

# Short session safety cap in ms (default: 86400000 = 24 hours)
# Applied when "Stay logged in" is UNCHECKED. The browser cookie is already
# session-scoped (deleted on browser close); this value caps the server-side
# expires_at so a misbehaving browser can't outlive the user's intent.
# Must be less than USER_SESSION_DURATION_MS.
# USER_SHORT_SESSION_DURATION_MS=86400000

# User session idle timeout in ms (default: 604800000 = 7 days)
# USER_IDLE_TIMEOUT_MS=604800000

# Bcrypt salt rounds for user password hashing (default: 12)
# USER_BCRYPT_ROUNDS=12

# Min password length (default: 10)
# USER_MIN_PASSWORD_LENGTH=10

# Max password length (default: 128)
# USER_MAX_PASSWORD_LENGTH=128

# Max failed login attempts before lockout (default: 5)
# USER_MAX_FAILED_LOGINS=5

# User lockout duration in ms (default: 900000 = 15 minutes)
# USER_LOCKOUT_DURATION_MS=900000

# User login rate limit — attempts per window per IP (default: 10)
# USER_LOGIN_RATE_LIMIT=10

# User login rate limit window in ms (default: 900000 = 15 minutes)
# USER_LOGIN_RATE_WINDOW_MS=900000

# User registration rate limit — registrations per window per IP (default: 3)
# USER_REGISTER_RATE_LIMIT=3

# User registration rate limit window in ms (default: 3600000 = 1 hour)
# USER_REGISTER_RATE_WINDOW_MS=3600000

# Max concurrent sessions per user (default: 5, oldest evicted)
# USER_MAX_SESSIONS=5

# User session cleanup interval in ms (default: 3600000 = 1 hour)
# USER_SESSION_CLEANUP_INTERVAL_MS=3600000

# ── OAuth (all optional — buttons auto-hide when unconfigured) ────────

# Google OAuth
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# Facebook OAuth
# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret

# Amazon OAuth (Login with Amazon)
# AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxxxx
# AMAZON_CLIENT_SECRET=your-client-secret

# Required when any OAuth provider is configured
# OAUTH_CALLBACK_BASE=https://price.games

# ── Cloudflare Turnstile (anti-bot CAPTCHA) ──────────────────────────

# When configured, registration requires a valid Turnstile token
# TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# Sandbox/dev escape hatch: skip Turnstile verification on /register and
# tell the web (via /api/user/auth-config) not to render the widget. Used
# by docker-compose.sandbox.yml. NEVER set in production.
# SKIP_TURNSTILE=1

# ── Product Universe (AI enrichment) ─────────────────────────────────

# Anthropic API key for AI-powered product enrichment
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Brave Search API key for product research
# BRAVE_SEARCH_API_KEY=BSA...

# AI provider and model (default: claude / claude-sonnet-4-20250514)
# PU_AI_PROVIDER=claude
# PU_AI_MODEL=claude-sonnet-4-20250514
# PU_RESEARCH_MODEL=claude-opus-4-20250514

# ── Chrome Extension ─────────────────────────────────────────────────

# Chrome extension ID for CORS (found at chrome://extensions)
# CHROME_EXTENSION_ID=abcdefghijklmnop

# ── Google Analytics (GA4) ─────────────────────────────────────────────

# GA4 Measurement ID is committed in apps/web/.env.production (public, non-sensitive).
# To override locally, set VITE_GA_MEASUREMENT_ID in apps/web/.env.

# ── 24/7 Bot Streamer ─────────────────────────────────────────────────
# The streamer service is opt-in via the `streamer` compose profile.
# Bring it up with:  docker compose --profile streamer up -d
#
# All STREAMER_* values are optional — without them the container exits
# at start (the runner refuses to launch with no destination keys set).

# URL the bot loads. REQUIRED — no default. Must be the host's tailnet
# hostname (e.g. https://onestreamer.tail-abcd.ts.net). The broadcast
# overlay is blocked on the public price.games domain at both the
# Caddy and Express layers (see docs/DEPLOYMENT.md § Tailscale Streamer
# Access). The runner refuses to start if this is unset or points at a
# known-public host (price.games, www.price.games, sandbox.price.games).
# STREAMER_TARGET_URL=https://onestreamer.tail-abcd.ts.net

# Optional: ADDITIONAL hostnames where the Express server returns 404
# for ?broadcast=1 requests. Values here are merged with the built-in
# defaults (price.games, www.price.games, sandbox.price.games), which
# are always protected — a typo or missing entry here cannot remove a
# default from the gate. Set this only when you front the server with
# an extra public hostname (e.g. a CDN edge or a vanity domain).
# BROADCAST_BLOCKED_HOSTS=mirror.example.com

# Bot identity. Constrained at the env-loader: name <= 32 chars,
# avatar slug must match /^[a-z0-9_-]+$/i (case-insensitive), voice
# must match /^[A-Za-z0-9_-]+$/ and be <= 64 chars.
# STREAMER_BOT_DISPLAY_NAME=Pricey
# STREAMER_BOT_AVATAR=wizard
# STREAMER_TTS_VOICE=en_US-amy-medium

# Skill temperature (0 = deterministic best, ~0.35 = competent player,
# ~1.0 = random over plausible options). Default 0.35.
# STREAMER_SKILL_TEMPERATURE=0.35

# Shared secret for the analytics-exclusion `X-Streamer-Bot` header. Set
# the SAME value on both the streamer container and the server (.env);
# the bot's Playwright context attaches it to every HTTP request + the
# Socket.IO handshake, and the server's streamerBotDetect middleware
# (apps/server/src/middleware/streamerBot.ts) gates analytics ingest,
# visitor-attribution counters, user_game_history, and mp_leaderboard
# writes for any session that matches. Empty / mismatched on either
# side = the bot's gameplay is counted like a regular client. Generate
# with `openssl rand -hex 32`.
# STREAMER_BOT_SECRET=...

# Per-round pace knobs. All default to 0; set to throttle the bot's
# round cadence and ease pressure on price.games' rate limit when the
# rotation is pinned to solo (which produces the fastest request rate).
#
# STREAMER_THINKING_PAD_MS — extra fixed sleep added after the natural
#   decision beat in Phase 2, before the enactor acts. Lengthens the
#   visible "thinking" beat on stream. Recommended 1500–3000.
# STREAMER_RESULT_LINGER_MS — per-round dwell on the round-result modal
#   (every round, including the final one). Stacks with the natural
#   decisionDelayMs jitter. Keep short — applies to every round
#   transition. Recommended 2000–3000.
# STREAMER_FINAL_LINGER_MS — dwell on the dedicated final-results page
#   that appears AFTER the last round's Next click navigates off the
#   modal (`[data-testid="result-page"]` from ResultPage.tsx). This is
#   where viewers want to absorb the final score before the lifecycle
#   picks a new plan, so it's typically much larger than the per-round
#   modal dwell. Recommended 8000–15000.
# STREAMER_THINKING_PAD_MS=2500
# STREAMER_RESULT_LINGER_MS=2500
# STREAMER_FINAL_LINGER_MS=12000

# Lifecycle plan rotation. When set, the runner switches to the legacy
# fixed-rotation picker (otherwise the default stateful picker uses
# probabilistic kind weights — solo:0.5, public_join:0.3, host_public:0.2 —
# and silently overrides any rotation array). Comma-separated list of
# steps from {solo, public_join, host_public}. Use `solo` to keep the
# bot off the multiplayer page entirely while no audience is around to
# fill rooms.
# STREAMER_ROTATION=solo

# Game-mode whitelist. When set, restricts the solo-mode picker to
# the listed modes. Useful while certain enactors are still being
# stabilised on stream. Unknown tokens are dropped with a warning.
# STREAMER_MODES=classic,higher-lower,comparison,closest-without-going-over,price-match,budget-builder,chain-reaction

# Encoder quality. 1080p30 @ 4500kbps fits under Twitch's 6000 cap
# with headroom; drop to 720p30 @ 2800kbps if the host CPU is tight.
# STREAMER_WIDTH=1920
# STREAMER_HEIGHT=1080
# STREAMER_FPS=30
# STREAMER_BITRATE_KBPS=4500

# Proactive browser recycle. The long-running kiosk Chromium is the
# host's biggest RSS consumer; renderer/X11-pixmap memory creeps up over
# hours. Every N lifecycle plans the runner relaunches a fresh browser so
# that memory is released (mood/stats persist across the recycle). Default
# 25; set 0 to disable. Backed by the host mem-watchdog
# (infra/streamer/pricey-mem-watchdog.*) as a hard safety net.
# STREAMER_BROWSER_RECYCLE_PLANS=25

# Online-learning subsystem — disabled by default. Worker thread
# trains a small multi-task NN alongside the heuristic estimator;
# `shadow` predicts and trains but the strategy ignores predictions,
# `active` lets predictions drive the strategy. Killswitch: flip
# `STREAMER_LEARNING_ENABLED=false` and `docker restart`. See
# docs/STREAMER.md § "Online learning subsystem".
# STREAMER_LEARNING_ENABLED=false
# STREAMER_LEARNING_MODE=off
# STREAMER_LEARNING_DATA_DIR=/var/streamer/data

# RTMP destinations — any subset. Each missing key disables that platform.
# STREAMER_YOUTUBE_KEY=xxxx-xxxx-xxxx-xxxx
# STREAMER_TWITCH_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STREAMER_KICK_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional Kick RTMP host override (Kick rotates these per-account):
# STREAMER_KICK_RTMP_HOST=fa723fc1b171.global-contribute.live-video.net

# Twitch chat (optional — bot reads chat for !commands).
# Anonymous read works without a token; set the OAuth one only if the
# bot should be able to chat back.
# STREAMER_TWITCH_CHANNEL=your-channel-name
# STREAMER_TWITCH_OAUTH=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Music directory on the host. Drop royalty-free .mp3/.flac/.ogg files
# in here; mpd loops them. Default is $HOME/streamer-music.
# STREAMER_MUSIC_HOST_DIR=/path/to/streamer-music

# Image tag for the streamer image. Defaults to `latest`; pin to a
# digest in production.
# STREAMER_IMAGE_TAG=latest
